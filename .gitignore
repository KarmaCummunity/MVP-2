# macOS
.DS_Store

# Supabase CLI
supabase/.temp/
supabase/.branches/

# IDE caches
.vscode/
.idea/

# Claude / agent worktree marker (the actual worktree dir is checked-in
# only as a metadata pointer; transient state inside it should not be
# tracked).
.claude/worktrees/*/.DS_Store
.claude/.DS_Store
.claude/scheduled_tasks.lock

# Agent PR body scratch file (generated per-PR by `gh pr create --body-file`).
.github/.pr-body.md

# Autonomous loop runtime artifacts (CLAUDE.md §13) — local-only.
.claude/AUTONOMOUS_LOOP_LOG.md
.claude/HALT_LOOP
.claude/LOOP_ENABLED

# Env files — never committed. Dev secrets live at ~/.kc-dev-secrets.env.
.env
.env.local
.env.*.local

# Aider AI coding assistant
.aider*
