{
  "name": "karma-community",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "pnpm lint:arch && turbo run lint",
    "lint:arch": "node scripts/check-architecture.mjs && node scripts/check-ssot-links.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "deps": "npx pnpm@9.0.0 install",
    "mobile": "npx pnpm@9.0.0 --filter @kc/mobile start",
    "mobile:go": "npx pnpm@9.0.0 --filter @kc/mobile run start:go",
    "mobile:go:tunnel": "npx pnpm@9.0.0 --filter @kc/mobile run start:go:tunnel",
    "ios": "npx pnpm@9.0.0 --filter @kc/mobile ios",
    "android": "npx pnpm@9.0.0 --filter @kc/mobile android",
    "build:web": "pnpm --filter @kc/mobile exec expo export -p web && node scripts/web-postbuild.mjs",
    "preview:web": "npx serve apps/mobile/dist --single",
    "check:migration-chain": "node ../scripts/check-migration-chain.mjs",
    "check:migration-safety": "node ../scripts/check-migration-safety.mjs",
    "check:rpc-contract": "node ../scripts/check-rpc-contract.mjs",
    "check:web-manifest": "node ../scripts/check-web-manifest.mjs",
    "check:backend-guards": "node ../scripts/check-migration-chain.mjs && node ../scripts/check-migration-safety.mjs && node ../scripts/check-rpc-contract.mjs",
    "test:scripts": "node --test ../scripts/check-migration-chain.test.mjs ../scripts/check-migration-safety.test.mjs ../scripts/check-rpc-contract.test.mjs ../scripts/check-web-manifest.test.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
