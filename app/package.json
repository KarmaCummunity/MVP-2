{
  "name": "karma-community",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "pnpm lint:arch && turbo run lint",
    "lint:arch": "node scripts/check-architecture.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "deps": "npx pnpm@9.0.0 install",
    "mobile": "npx pnpm@9.0.0 --filter @kc/mobile start",
    "mobile:go": "npx pnpm@9.0.0 --filter @kc/mobile run start:go",
    "mobile:go:tunnel": "npx pnpm@9.0.0 --filter @kc/mobile run start:go:tunnel",
    "ios": "npx pnpm@9.0.0 --filter @kc/mobile ios",
    "android": "npx pnpm@9.0.0 --filter @kc/mobile android",
    "build:web": "pnpm --filter @kc/mobile exec expo export -p web && node scripts/web-postbuild.mjs",
    "preview:web": "npx serve apps/mobile/dist --single"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
