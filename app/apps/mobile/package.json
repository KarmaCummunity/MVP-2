{
  "name": "@kc/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "start": "expo start --dev-client",
    "start:go": "expo start --go",
    "start:go:tunnel": "expo start --go --tunnel",
    "ios": "expo run:ios",
    "android": "JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home expo run:android",
    "web": "node ../../../scripts/generate-web-manifest.mjs && expo start --web",
    "build:web": "node ../../../scripts/generate-web-manifest.mjs && expo export --platform web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.0",
    "@expo/metro-runtime": "55.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@kc/application": "workspace:*",
    "@kc/domain": "workspace:*",
    "@kc/infrastructure-supabase": "workspace:*",
    "@kc/ui": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.69.0",
    "@tanstack/react-query": "^5.62.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.34",
    "expo-auth-session": "~55.0.16",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.34",
    "expo-device": "~55.0",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.14",
    "expo-notifications": "~55.0",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.16",
    "i18next": "^23.16.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "whatwg-fetch": "^3.6.20",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.17",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
