    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.18",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.14",
