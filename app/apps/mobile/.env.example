# Copy to `.env` and fill values. `.env` is gitignored.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only: when "1", a ghost session bypass is wired in (do NOT set in prod).
EXPO_PUBLIC_DEV_GHOST_SESSION=0

# Auth verification deep link (universal link in prod; custom scheme in dev).
EXPO_PUBLIC_AUTH_VERIFY_URL=https://karma-community-kc.com/auth/verify

# FR-AUTH-002 (web sheet) — Google Identity Services Web Client ID.
# Create in Google Cloud Console → APIs & Services → Credentials → "OAuth client ID"
# of type "Web application". Authorized JavaScript origins must include each web
# origin (e.g. http://localhost:8081, http://localhost:19006, the prod web origin).
# The same client ID must be registered as an allowed audience in Supabase Auth →
# Providers → Google. When unset, the web Google sheet shows a config error
# (native iOS/Android paths keep working since they use a different OAuth flow).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
