# Supabase — copy to .env and fill in your values
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# FR-POST-023 — branded share URL prefix. When set, the post share sheet hands
# recipients `<prefix>/<post_id>` (e.g. https://karma-community-kc.com/p/<id>)
# instead of the raw Edge Function URL. The matching host must redirect
# `/p/:id` to `${EXPO_PUBLIC_SUPABASE_URL}/functions/v1/share-post/:id` —
# the Railway/`serve` build does this automatically via the `serve.json`
# emitted by `app/scripts/web-postbuild.mjs`. Leave unset to fall back to
# the raw Supabase URL.
# EXPO_PUBLIC_SHARE_BASE_URL=https://karma-community-kc.com/p

# ───────────────────────────────────────────────────────────────────
# DEV-ONLY auth shortcuts. BOTH are compiled out of production bundles
# by `__DEV__` (Metro/Expo replace it with `false` and dead-code-
# eliminate the entire branch — neither the env-var read, the API
# call, the fake JWT, nor the test credentials end up in dist/).
#
# Pick ONE of the two modes (not both — ghost wins if both are set).
# Leave commented out on every CI / production environment.
# See docs/dev/AUTO_SIGN_IN.md for the full rationale + ops checklist.
# ───────────────────────────────────────────────────────────────────

# Mode A — GHOST SESSION: instant fake JWT for layout-only inspection.
# Supabase queries 401, but every screen renders so you can audit RTL,
# spacing, navigation. Use when iterating on UI; no network needed.
# EXPO_PUBLIC_DEV_GHOST_SESSION=1

# Mode B — AUTO SIGN-IN: real Supabase auth with a test user. Full
# functionality (data loads, mutations work). Slower; needs a maintained
# test password. Triple-gated: flag AND email AND password.
# EXPO_PUBLIC_DEV_AUTO_SIGN_IN=1
# EXPO_PUBLIC_DEV_TEST_EMAIL=karmacommunity2.0@gmail.com
# EXPO_PUBLIC_DEV_TEST_PASSWORD=your-test-password-here
